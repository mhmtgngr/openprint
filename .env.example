# OpenPrint Cloud Environment Variables
# Copy this file to .env and configure your settings

# ===========================================
# Required Variables
# ===========================================

# JWT Secret (MUST be at least 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-characters-change-this

# Database Connection
DATABASE_URL=postgres://openprint:openprint@localhost:5432/openprint

# Redis Connection (optional, defaults to localhost)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Service Configuration
# ===========================================

# Server Address (override default ports)
# SERVER_ADDR=:8001

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Test Mode (enables test-friendly behavior)
TEST_MODE=true

# ===========================================
# Service URLs (for API Gateway)
# ===========================================

AUTH_SERVICE_URL=http://localhost:8001
REGISTRY_SERVICE_URL=http://localhost:8002
JOB_SERVICE_URL=http://localhost:8003
STORAGE_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005
ANALYTICS_SERVICE_URL=http://localhost:8006
ORGANIZATION_SERVICE_URL=http://localhost:8007

# ===========================================
# Storage Configuration
# ===========================================

# S3/Object Storage (optional, falls back to local storage)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=openprint-documents
# S3_REGION=us-east-1

# Local Storage Path (fallback)
STORAGE_PATH=/var/lib/openprint/storage

# Encryption Key (optional, AES-256 key for document encryption)
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=your-encryption-key-change-this

# ===========================================
# M365 Integration (optional)
# ===========================================

# Microsoft 365 Integration Storage
M365_STORAGE_PATH=/var/lib/openprint/m365

# ===========================================
# Monitoring & Tracing (optional)
# ===========================================

# Jaeger Tracing Endpoint
# JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Prometheus Metrics Port (default: 9090)
# METRICS_PORT=9090

# ===========================================
# Rate Limiting (optional)
# ===========================================

# Default rate limits
# RATE_LIMIT_REQUESTS_PER_MINUTE=100
# RATE_LIMIT_BURST=20

# ===========================================
# Security (optional)
# ===========================================

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Cookie Settings
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# ===========================================
# Docker-specific (used in docker-compose.yml)
# ===========================================

# PostgreSQL Settings
POSTGRES_USER=openprint
POSTGRES_PASSWORD=openprint
POSTGRES_DB=openprint

# Redis Settings
REDIS_PASSWORD=openprint

# ===========================================
# Dashboard Configuration
# ===========================================

# API Base URL for Dashboard
VITE_API_BASE_URL=http://localhost:18001
VITE_WS_URL=ws://localhost:18005/ws
