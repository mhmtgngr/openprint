# OpenPrint Docker Deployment Environment Variables
# Copy this file to .env and configure values for your deployment

# ============================================
# REQUIRED
# ============================================

# JWT Secret - Must be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-secret-in-production-min-32-chars

# ============================================
# OPTIONAL - Storage
# ============================================

# S3 Storage Configuration
# Leave empty to use local filesystem storage
S3_ENDPOINT=
S3_BUCKET=openprint-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Encryption Key for document storage (AES-256)
# Leave empty to disable encryption
ENCRYPTION_KEY=

# ============================================
# OPTIONAL - Observability
# ============================================

# Jaeger Tracing - defaults to jaeger:4317 (internal)
# Set to empty to disable tracing
JAEGER_ENDPOINT=

# Grafana credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================
# OPTIONAL - Microsoft 365 Integration
# ============================================

# Required for OneDrive/SharePoint document integration
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
M365_REDIRECT_URI=http://localhost:3000/auth/m365/callback

# ============================================
# OPTIONAL - Environment
# ============================================

# Set to "production" for production deployments
ENVIRONMENT=development
