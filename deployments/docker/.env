# JWT Secret - REQUIRED - Must be at least 32 characters
# Generate a secure random secret for production
JWT_SECRET=change-this-secret-in-production-min-32-chars

# Jaeger Tracing (Optional)
# Leave empty to disable tracing
JAEGER_ENDPOINT=

# S3 Storage Configuration (Optional)
# Leave empty to use local filesystem storage
S3_ENDPOINT=
S3_BUCKET=openprint-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Encryption Key for Storage (Optional)
# Leave empty to disable encryption
ENCRYPTION_KEY=

# Dashboard API Base URL
VITE_API_BASE_URL=http://localhost:8001
