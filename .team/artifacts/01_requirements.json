    {
      "risk": "Print job may fail silently if printer is offline or out of paper, causing user frustration",
      "mitigation": "Query printer status before printing, show clear error messages with actionable guidance, implement retry with delay"
    },
    {
      "risk": "Agent may overwhelm job-service with excessive polling if many agents are deployed",
      "mitigation": "Use configurable poll intervals, implement exponential backoff on errors, consider WebSocket push for future"
