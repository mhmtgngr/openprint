  "database_migrations": [
    {
      "file": "migrations/000001_create_load_test_schema.up.sql",
      "sql": "-- Create separate schema for load testing\nCREATE SCHEMA IF NOT EXISTS load_test;\n\n-- Load test results table\nCREATE TABLE load_test.test_results (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    test_name VARCHAR(255) NOT NULL,\n    test_type VARCHAR(100) NOT NULL,\n    service VARCHAR(100) NOT NULL,\n    started_at TIMESTAMP WITH TIME ZONE NOT NULL,\n    ended_at TIMESTAMP WITH TIME ZONE,\n    duration_seconds INTEGER,\n    virtual_users INTEGER,\n    total_requests BIGINT,\n    failed_requests BIGINT,\n    avg_response_time_ms NUMERIC(10,2),\n    p50_response_time_ms NUMERIC(10,2),\n    p95_response_time_ms NUMERIC(10,2),\n    p99_response_time_ms NUMERIC(10,2),\n    max_response_time_ms NUMERIC(10,2),\n    requests_per_second NUMERIC(10,2),\n    throughput_mb_per_second NUMERIC(10,2),\n    threshold_met BOOLEAN,\n    git_commit VARCHAR(100),\n    git_branch VARCHAR(255),\n    metadata JSONB,\n    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()\n);\n\nCREATE INDEX idx_load_test_results_test_name ON load_test.test_results(test_name);\nCREATE INDEX idx_load_test_results_service ON load_test.test_results(service);\nCREATE INDEX idx_load_test_results_started_at ON load_test.test_results(started_at DESC);\n\n-- Performance baselines table\nCREATE TABLE load_test.baselines (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    service VARCHAR(100) NOT NULL,\n    endpoint VARCHAR(255) NOT NULL,\n    metric_name VARCHAR(100) NOT NULL,\n    baseline_value NUMERIC(10,2) NOT NULL,\n    tolerance_percent NUMERIC(5,2) DEFAULT 10.0,\n    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\n    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\n    UNIQUE(service, endpoint, metric_name)\n);\n\n-- Load test users for isolated authentication\nCREATE TABLE load_test.test_users (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    username VARCHAR(255) UNIQUE NOT NULL,\n    email VARCHAR(255) UNIQUE NOT NULL,\n    password_hash VARCHAR(255) NOT NULL,\n    role VARCHAR(50) DEFAULT 'user',\n    is_active BOOLEAN DEFAULT true,\n    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()\n);\n\n-- Load test agents\nCREATE TABLE load_test.test_agents (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    agent_id VARCHAR(100) UNIQUE NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    status VARCHAR(50) DEFAULT 'online',\n    printer_count INTEGER DEFAULT 1,\n    location VARCHAR(255),\n    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()\n);"
    },
    {
      "file": "migrations/000001_create_load_test_schema.down.sql",
      "sql": "DROP SCHEMA load_test CASCADE;"
    },
    {
      "file": "migrations/000002_seed_load_test_data.up.sql",
      "sql": "-- Seed load test users\nINSERT INTO load_test.test_users (username, email, password_hash, role) VALUES\n    ('load_test_user_001', 'loadtest1@example.com', '$2a$10$placeholder_hash_for_testing', 'user'),\n    ('load_test_user_002', 'loadtest2@example.com', '$2a$10$placeholder_hash_for_testing', 'user'),\n    ('load_test_user_003', 'loadtest3@example.com', '$2a$10$placeholder_hash_for_testing', 'user'),\n    ('load_test_admin_001', 'loadtest_admin@example.com', '$2a$10$placeholder_hash_for_testing', 'admin');\n\n-- Seed load test agents\nINSERT INTO load_test.test_agents (agent_id, name, status, printer_count, location) VALUES\n    ('load-test-agent-001', 'Load Test Agent 1', 'online', 3, 'Building A'),\n    ('load-test-agent-002', 'Load Test Agent 2', 'online', 2, 'Building B'),\n    ('load-test-agent-003', 'Load Test Agent 3', 'online', 5, 'Building C');\n\n-- Seed initial performance baselines\nINSERT INTO load_test.baselines (service, endpoint, metric_name, baseline_value, tolerance_percent) VALUES\n    ('auth-service', 'POST /api/v1/auth/login', 'p95_response_time_ms', 200, 15),\n    ('auth-service', 'POST /api/v1/auth/login', 'requests_per_second', 500, 10),\n    ('registry-service', 'POST /api/v1/agents/heartbeat', 'p95_response_time_ms', 50, 20),\n    ('registry-service', 'POST /api/v1/agents/heartbeat', 'requests_per_second', 5000, 10),\n    ('job-service', 'POST /api/v1/jobs', 'p95_response_time_ms', 150, 15),\n    ('job-service', 'POST /api/v1/jobs', 'requests_per_second', 1000, 10),\n    ('storage-service', 'POST /api/v1/documents', 'p95_response_time_ms', 500, 20),\n    ('storage-service', 'POST /api/v1/documents', 'throughput_mb_per_second', 50, 15),\n    ('notification-service', 'WebSocket /ws/connect', 'connection_time_ms', 100, 25);"
    },
    {
      "file": "migrations/000002_seed_load_test_data.down.sql",
      "sql": "TRUNCATE TABLE load_test.baselines, load_test.test_agents, load_test.test_users;"
