{
  "architecture_decisions": [
    {
      "decision": "Use k6 as primary load testing tool with xk6-dashboard for real-time visualization",
      "rationale": "k6 is JavaScript-based, has excellent CI/CD integration, supports WebSocket testing, and provides developer-friendly script syntax. xk6-dashboard enables real-time metrics visualization during test runs."
    },
    {
      "decision": "Separate test environments with dedicated database schema",
      "rationale": "Load tests should never run against production or development databases. Dedicated test schema ensures isolation and prevents test data pollution."
    },
    {
      "decision": "Modular test architecture with reusable scenario libraries",
      "rationale": "Promotes code reuse across tests, simplifies maintenance, and enables consistent testing patterns across all services."
    },
    {
      "decision": "Performance baselines stored as JSON artifacts in CI",
      "rationale": "Enables regression detection by comparing current test results against historical baselines stored in version control."
    },
    {
      "decision": "Kubernetes k6-operator for production-like load testing",
      "rationale": "Enables distributed load generation from multiple pods, simulating real-world traffic patterns more accurately than single-machine tests."
    }
  ],
