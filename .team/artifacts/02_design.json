  "database_migrations": [
    {
      "file": "migrations/000001_create_users_table.up.sql",
      "sql": "CREATE TABLE users (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    email VARCHAR(255) UNIQUE NOT NULL,\n    password_hash VARCHAR(255),\n    full_name VARCHAR(255),\n    role VARCHAR(50) DEFAULT 'user',\n    mfa_enabled BOOLEAN DEFAULT false,\n    mfa_secret VARCHAR(255),\n    smart_card_id VARCHAR(255) UNIQUE,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000002_create_printers_table.up.sql",
      "sql": "CREATE TABLE printers (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    name VARCHAR(255) NOT NULL,\n    agent_id VARCHAR(255) UNIQUE NOT NULL,\n    ip_address INET,\n    status VARCHAR(50) DEFAULT 'offline',\n    capabilities JSONB,\n    location VARCHAR(255),\n    last_heartbeat TIMESTAMP,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000003_create_jobs_table.up.sql",
      "sql": "CREATE TABLE print_jobs (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    document_id UUID NOT NULL REFERENCES documents(id),\n    printer_id UUID REFERENCES printers(id),\n    status VARCHAR(50) DEFAULT 'queued',\n    priority INTEGER DEFAULT 0,\n    pages INTEGER DEFAULT 0,\n    color_pages INTEGER DEFAULT 0,\n    duplex BOOLEAN DEFAULT false,\n    cost_cents INTEGER DEFAULT 0,\n    pin VARCHAR(255),\n    released_at TIMESTAMP,\n    completed_at TIMESTAMP,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000004_create_documents_table.up.sql",
      "sql": "CREATE TABLE documents (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    filename VARCHAR(255) NOT NULL,\n    storage_key VARCHAR(255) UNIQUE NOT NULL,\n    content_type VARCHAR(100),\n    size_bytes BIGINT,\n    encryption_enabled BOOLEAN DEFAULT false,\n    checksum VARCHAR(255),\n    uploaded_by UUID REFERENCES users(id),\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000005_create_quotas_table.up.sql",
      "sql": "CREATE TABLE quotas (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id UUID UNIQUE NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    period_type VARCHAR(50) DEFAULT 'monthly',\n    page_limit INTEGER DEFAULT 0,\n    pages_used INTEGER DEFAULT 0,\n    cost_limit_cents INTEGER DEFAULT 0,\n    cost_used_cents INTEGER DEFAULT 0,\n    reset_at TIMESTAMP,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000006_create_policies_table.up.sql",
      "sql": "CREATE TABLE policies (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    rules JSONB NOT NULL,\n    priority INTEGER DEFAULT 0,\n    enabled BOOLEAN DEFAULT true,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    },
    {
      "file": "migrations/000007_create_policy_assignments_table.up.sql",
      "sql": "CREATE TABLE policy_assignments (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    policy_id UUID NOT NULL REFERENCES policies(id) ON DELETE CASCADE,\n    user_id UUID REFERENCES users(id) ON DELETE CASCADE,\n    group_id UUID REFERENCES groups(id) ON DELETE CASCADE,\n    CONSTRAINT target_exclusion CHECK (\n        (user_id IS NOT NULL)::integer + (group_id IS NOT NULL)::integer = 1\n    )\n)"
    },
    {
      "file": "migrations/000008_create_sessions_table.up.sql",
      "sql": "CREATE TABLE sessions (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    token_hash VARCHAR(255) UNIQUE NOT NULL,\n    expires_at TIMESTAMP NOT NULL,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    last_used_at TIMESTAMP\n)"
    },
    {
      "file": "migrations/000009_create_release_history_table.up.sql",
      "sql": "CREATE TABLE release_history (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    job_id UUID NOT NULL REFERENCES print_jobs(id) ON DELETE CASCADE,\n    user_id UUID REFERENCES users(id),\n    release_method VARCHAR(50) NOT NULL,\n    released_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    printer_id UUID REFERENCES printers(id),\n    ip_address INET\n)"
    },
    {
      "file": "migrations/000010_create_analytics_events_table.up.sql",
      "sql": "CREATE TABLE analytics_events (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    event_type VARCHAR(100) NOT NULL,\n    user_id UUID REFERENCES users(id),\n    printer_id UUID REFERENCES printers(id),\n    properties JSONB,\n    occurred_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
    }
  ],
