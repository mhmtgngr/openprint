{
  "architecture_decisions": [
    {
      "decision": "Use prometheus/client_golang for metrics collection with custom registry per service",
      "rationale": "Standard Go Prometheus client, provides histogram/counter/gauge primitives, enables efficient scraping on separate metrics port"
    },
    {
      "decision": "Expose /metrics endpoint on port 9090 separate from service HTTP port",
      "rationale": "Isolates metrics traffic from application traffic, allows security rules specifically for metrics endpoints, prevents port conflicts"
    },
    {
      "decision": "Implement middleware-based HTTP metrics collection",
      "rationale": "Non-invasive pattern, automatically captures all HTTP endpoints, consistent across all microservices"
    },
    {
      "decision": "Use OpenTelemetry for distributed tracing with Jaeger backend",
      "rationale": "Vendor-neutral standard, already exists in internal/shared/telemetry, provides trace context propagation across services"
    },
    {
      "decision": "Grafana dashboard provisioning via filesystem",
      "rationale": "Infrastructure-as-code approach, dashboards version controlled, automatic loading on container start"
    },
    {
      "decision": "Redis metrics via go-redis/redis/extra/redisotel",
      "rationale": "Native integration with go-redis v8+, provides command duration, connection pool metrics, and error tracking"
    },
    {
      "decision": "Database metrics via sqlstats wrapper",
      "rationale": "Standard database/sql instrumentation, tracks connection pool, query latency, and row counts without code changes"
    }
  ],
