{
  "architecture_decisions": [
    {
      "decision": "Use testcontainers-go for all external dependencies (PostgreSQL, Redis, S3)",
      "rationale": "Provides real containerized dependencies matching production, more reliable than mocks, supports parallel test execution with unique containers per test"
    },
    {
      "decision": "Create internal/testutil as standalone package with no external dependencies on services",
      "rationale": "Makes test utilities reusable across all services, prevents circular dependencies, allows tests to run independently"
    },
    {
      "decision": "Implement cleanup registry with t.Cleanup() pattern",
      "rationale": "Guarantees resource cleanup even on test failure, prevents dangling containers, follows Go testing best practices"
    },
    {
      "decision": "Add build tag integration for tests requiring containers",
      "rationale": "Allows unit tests to run fast without containers, integration tests opt-in with //go:build integration"
    },
    {
      "decision": "Implement shared test fixtures package",
      "rationale": "Reduces test setup duplication, provides consistent test data across services, maintains test data invariants"
    },
    {
      "decision": "Add Makefile test targets with dependency checking",
      "rationale": "Simplifies developer workflow, ensures Docker is available before running containerized tests, provides single entry point for all test types"
    }
  ],
