# E2E Test Environment Variables Example
# Copy this file to .env.local and fill in your values

# Base URLs for different environments
DEV_URL=http://localhost:3000
STAGING_URL=https://staging.openprint.cloud
PRODUCTION_URL=https://openprint.cloud

# Test credentials
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=AdminPassword123!

# API Configuration (if testing against real backend)
API_BASE_URL=http://localhost:8001
API_TIMEOUT=30000

# Feature Flags
TEST_VISUAL_REGRESSION=true
TEST_ACCESSIBILITY=true
TEST_PERFORMANCE=false

# BrowserStack/Capabilities (for cross-browser testing)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_BUILD=

# Test Configuration
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=retain-on-failure
TEST_TIMEOUT=60000
